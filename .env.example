# Copy to .env locally; never commit real credentials.
PLAYWRIGHT_LOGIN_URL=https://example.invalid/login
PLAYWRIGHT_USERNAME=replace-me
PLAYWRIGHT_PASSWORD=replace-me
PLAYWRIGHT_TEST_CALLER_NUMBER=replace-me

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=workflow_builder
DB_USERNAME=replace-me
DB_PASSWORD=replace-me

# Optional Phase 4 multi-process picker routing. Leave unset for local
# single-process development.
PICKER_REDIS_URL=redis://127.0.0.1:6379/1
