    "version": "0.2.0",
  "configurations": [
    {
			"name": "Debug pytest test_call digi",
			"type": "debugpy",
			"request": "launch",
			"module": "pytest",
			"cwd": "${workspaceFolder}",
			"args": [
				"tests/test_call.py",
				"--brand",
				"Digi",
				"--headed",
				"--slowmo",
				"1000",
				"--alluredir=allure-results-call"
			],
			"console": "integratedTerminal",
			"justMyCode": false
		}
  ]
}
